# OrderEase 统一部署配置文件
# 适用于 front-iui 和 admin-iui 共用同一后台服务的场景
# 运行时请替换为实际值

# ==================== 后端 API 配置 ====================
# 两个前端 UI 共用同一个后端 API 地址
# 格式: http://IP:端口 或 https://域名
VITE_API_BASE_URL=http://your-api-server:8080
VITE_API_PREFIX=/api/order-ease/v1

# ==================== 数据库配置 ====================
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=YourStrongPassword123!
DB_NAME=orderease

# ==================== JWT 配置 ====================
# JWT 密钥至少需要 32 字节
JWT_SECRET=your_jwt_secret_minimum_32_bytes_long
JWT_EXPIRATION=7200

# ==================== 服务器配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ==================== 时区配置 ====================
TZ=Asia/Shanghai
# ==================== 微信小程序配置 ====================
# 是否启用微信小程序登录
WECHAT_MINIPROGRAM_ENABLED=false
# 小程序 AppID（从微信公众平台获取）
WECHAT_MINIPROGRAM_APP_ID=
# 小程序 AppSecret（从微信公众平台获取，敏感信息请妥善保管）
WECHAT_MINIPROGRAM_APP_SECRET=