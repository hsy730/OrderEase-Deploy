# MySQL 8.0 Configuration - Optimized for 2GB RAM Server
# Total Memory Budget: ~800MB allocated to MySQL container
# ============================================
# MEMORY ALLOCATION SUMMARY
# ============================================
# InnoDB Buffer Pool:    400MB ( (50% of container memory)
# InnoDB Log Buffer:     16MB  (2% of container memory)
# Thread Stack:          ~28MB (8 threads x ~3.5MB each)
# Connection Buffers:   ~50MB (50 connections)
# Query Cache:           0MB  (Disabled in MySQL 8.0)
# Performance Schema:    0MB  (Disabled to save memory)
# Key Buffer:            16MB  (for MyISAM tables if any)
# Other Structures:      ~200MB (metadata, network buffers, etc.)
# ============================================
# ESTIMATED TOTAL:       ~710MB (leaves ~90MB headroom)
# ============================================

[mysqld]
# ============================================
# CHARACTER SET & COLLATION
# ============================================
character-set-server=utf8mb4
collation-server=utf8mb4_unicode_ci
init-connect='SET NAMES utf8mb4'

# ============================================
# CONNECTION SETTINGS
# ============================================
# Reduced from default 151 to save memory
max_connections=50
# Maximum connections per user
max_user_connections=40
# Wait timeout for idle connections (seconds)
wait_timeout=600
# Interactive timeout for interactive clients (seconds)
interactive_timeout=600

# ============================================
# INNODB SETTINGS - Core Performance Tuning
# ============================================
# InnoDB Buffer Pool Size - The most critical MySQL memory setting
# Allocates 400MB for caching table data and indexes
# Formula: Available Memory - (Thread Stack + Buffer Pool + Other Allocations) ~ 50-60%
innodb_buffer_pool_size=400M

# Number of buffer pool instances (divides buffer pool for concurrency)
# Good practice: 1 instance per GB, rounded up
innodb_buffer_pool_instances=1

# InnoDB Log File Size - Controls redo log size
# Smaller size reduces memory usage but increases log rotation frequency
# 16M is a good balance for small databases
innodb_log_file_size=16M
innodb_log_buffer_size=16M

# InnoDB Flush Log Log at Transaction Commit
log at Transaction Commit
# 1 = Flush to disk on every commit (safest, slower)
# 2 = Flush to OS cache on commit, flush to disk every second (good balance)
# 0 = Write to OS cache, no flush until log buffer full (fastest, potential data loss)
innodb_flush_log_at_trx_commit=2

# InnoDB Flush Method
# O' _DIRECT bypasses OS cache to avoid double buffering
innodb_flush_method=O_DIRECT

# InnoDB I/O Threads
innodb_read_io_threads=4
innodb_write_io_threads=4

# InnoDB File Format
innodb_file_per_table=1

# InnoDB Lock Wait Timeout (seconds)
innodb_lock_wait_timeout=50

# ============================================
# MYISAM SETTINGS (if any MyISAM tables exist)
# ============================================
# Key buffer size for MyISAM index caching
key_buffer_size=16M

# ============================================
# QUERY CACHE (Disabled in MySQL 8.0 - removed)
# ============================================
# No query_cache_size setting - MySQL 8.0 removed query cache

# ============================================
# THREAD SETTINGS
# ============================================
# Thread cache size - reduces thread creation overhead
thread_cache_size=8

# Thread stack size per thread (default is usually 256KB to 512KB)
# MySQL 8.0 default is 1MB on Linux
# With 50 connections: 8 threads * ~3.5MB each = ~28MB
thread_stack=256K

# ============================================
# TABLE & CACHE SETTINGS
# ============================================
# Table definition cache - stores table metadata
# Reduced from default 2000
table_definition_cache=400

# Table open cache - number of open tables cached
# Reduced from default 4000
table_open_cache=400
table_open_cache_instances=1

# Sort buffer size - used for ORDER BY, GROUP BY
# Reduced from per-session default 256KB
sort_buffer_size=256K

# Join buffer size - used for joins without indexes
join_buffer_size=256K

# Read buffer size - used for table scans
read_buffer_size=128K
read_rnd_buffer_size=256K

# ============================================
# QUERY EXECUTION SETTINGS
# ============================================
# Binary logging - disable if not using replication
# Set to 0 (OFF) to save disk I/O and memory
# Set to 1 (ROW) if replication is needed
log_bin=0

# Slow query log - useful for optimization
slow_query_log=1
slow_query_log_file=/var/lib/mysql/slow-query.log
long_query_time=2

# General query log - disabled in production
general_log=0

# ============================================
# PERFORMANCE SCHEMA
# ============================================
# Performance schema is memory-intensive (~50-100MB default)
# Disabled to save memory on resource-constrained servers
performance_schema=0

# ============================================
# NETWORK SETTINGS
# ============================================
# Maximum allowed packet size
max_allowed_packet=16M

# Connection timeout (seconds)
connect_timeout=10

# ============================================
# LOGGING & SAFETY
# ============================================
# Disable symbolic links for security
symbolic_links=0

# Local Infile - disabled for security
local_infile=0

# ============================================
# TEMPORARY TABLE SETTINGS
# ============================================
# Temporary table size - uses memory before disk
tmp_table_size=32M
max_heap_table_size=32M

# ============================================
# MODE SETTINGS
# ============================================
# SQL mode - STRICT_TRANS_TABLES is important for data integrity
sql_mode=STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[client]
default-character-set=utf8mb4

[mysql]
default-character-set=utf8mb4
